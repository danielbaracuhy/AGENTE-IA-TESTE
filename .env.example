# Copie para .env e preencha. O .env real NUNCA vai pro GitHub.
# No Vercel, cadastre estas MESMAS variáveis em Settings > Environment Variables.
META_ACCESS_TOKEN=cole_aqui_o_token_de_longa_duracao
META_AD_ACCOUNT_ID=act_000000000000000
META_PAGE_ID=000000000000000
META_PIXEL_ID=000000000000000
# Número WhatsApp com código do país, só dígitos (ex.: 5517991414397)
META_WHATSAPP_NUMBER=55119XXXXXXXX
# Supabase (necessário para leitura de meta_config do cliente logado)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SECRET_KEY=service_role_secret_aqui
